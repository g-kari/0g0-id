{
  "name": "workers-user",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "build:frontend": "cd frontend && npm ci && npm run build",
    "preflight:deploy": "tsx scripts/preflight-deploy.ts",
    "deploy": "npm run preflight:deploy && vp build && npm run build:frontend && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vp test run --passWithNoTests"
  },
  "dependencies": {
    "@0g0-id/shared": "*",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.3",
    "@cloudflare/workers-types": "^4.20260416.2",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "^0.1.18",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wrangler": "^4.78.0"
  }
}
