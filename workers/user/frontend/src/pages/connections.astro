---
import Base from '../layouts/Base.astro';
---
<Base title="0g0 ID - 連携サービス">
  <div class="min-h-screen flex items-center justify-center p-4">
    <div class="w-full" style="max-width: 480px">
      <div class="card">
        <div class="flex items-center justify-between mb-4">
          <h1 class="text-2xl font-bold">連携サービス</h1>
          <a href="/profile" class="btn btn-ghost btn-sm">← プロフィール</a>
        </div>
        <p class="text-sm mb-6" style="color: var(--color-muted)">
          アクセスを許可しているサービスの一覧です。不要なサービスは連携を解除できます。
        </p>

        <div id="loading" class="flex items-center justify-center gap-2 py-8" style="color: var(--color-muted)">
          <span class="spinner"></span>
          <span>読み込み中...</span>
        </div>
        <div id="error" class="alert alert-error" style="display:none"></div>
        <div id="empty" class="text-center py-8" style="color: var(--color-muted); display:none">連携中のサービスはありません</div>
        <div id="list" style="display:none"></div>
      </div>
    </div>
  </div>
</Base>

<script>
  import { apiFetch, formatDate } from '../lib/api';
  import { escapeHtml } from '../lib/helpers';
  import { showToast } from '../lib/toast';
  import type { UserConnection } from '@0g0-id/api-types';

  const loadingEl = document.getElementById('loading')!;
  const errorEl = document.getElementById('error')!;
  const emptyEl = document.getElementById('empty')!;
  const listEl = document.getElementById('list')!;

  async function loadConnections() {
    loadingEl.style.display = '';
    errorEl.style.display = 'none';
    emptyEl.style.display = 'none';
    listEl.style.display = 'none';

    const res = await apiFetch<UserConnection[]>('/api/connections');
    loadingEl.style.display = 'none';
    if ('error' in res) {
      errorEl.textContent = '連携サービスの取得に失敗しました';
      errorEl.style.display = '';
      return;
    }
    const connections = res as UserConnection[];
    if (connections.length === 0) {
      emptyEl.style.display = '';
      return;
    }
    listEl.innerHTML = connections.map(c => `
      <div class="flex items-center justify-between py-3.5 border-b last:border-b-0" style="border-color: var(--color-border)">
        <div class="flex-1 min-w-0">
          <div class="font-semibold text-sm truncate">${escapeHtml(c.service_name)}</div>
          <div class="text-xs mt-0.5" style="color: var(--color-muted)">連携日: ${formatDate(c.first_authorized_at)}</div>
        </div>
        <button class="btn btn-danger btn-sm ml-3" data-disconnect="${escapeHtml(c.service_id)}" data-name="${escapeHtml(c.service_name)}">解除</button>
      </div>
    `).join('');
    listEl.style.display = '';
  }

  listEl.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('[data-disconnect]') as HTMLElement | null;
    if (!btn) return;
    const id = btn.dataset.disconnect!;
    const name = btn.dataset.name!;
    if (!confirm(`「${name}」との連携を解除しますか？`)) return;
    const res = await apiFetch(`/api/connections/${id}`, {
      method: 'DELETE',
      headers: { Origin: window.location.origin },
    });
    if ('error' in res) {
      showToast('解除に失敗しました', 'error');
    } else {
      showToast('連携を解除しました', 'success');
      await loadConnections();
    }
  });

  await loadConnections();
</script>
