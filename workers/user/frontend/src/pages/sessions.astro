---
import Base from '../layouts/Base.astro';
---
<Base title="0g0 ID - ログイン中のデバイス">
  <div class="min-h-screen flex items-center justify-center p-4">
    <div class="w-full" style="max-width: 560px">
      <div class="card">
        <div class="flex items-center justify-between mb-4">
          <h1 class="text-2xl font-bold">ログイン中のデバイス</h1>
          <a href="/profile" class="btn btn-ghost btn-sm">← プロフィール</a>
        </div>
        <p class="text-sm mb-6" style="color: var(--color-muted)">
          現在アクティブなセッションの一覧です。身に覚えのないセッションは無効化してください。
        </p>

        <h2 class="text-lg font-semibold mb-2">このブラウザのセッション</h2>
        <p class="text-xs mb-3" style="color: var(--color-muted)">
          ログイン済みブラウザごとの Cookie セッション。TPM バインド済み（DBSC）のセッションはハードウェア鍵でセッションハイジャック耐性があります。
        </p>
        <div id="bff-loading" class="flex items-center justify-center gap-2 py-4" style="color: var(--color-muted)">
          <span class="spinner"></span>
          <span>読み込み中...</span>
        </div>
        <div id="bff-error" class="alert alert-error" style="display:none"></div>
        <div id="bff-empty" class="text-center py-4" style="color: var(--color-muted); display:none">アクティブなブラウザセッションはありません</div>
        <div id="bff-list" style="display:none"></div>

        <hr class="my-5" style="border-color: var(--color-border)" />

        <h2 class="text-lg font-semibold mb-2">連携アプリケーション</h2>
        <p class="text-xs mb-3" style="color: var(--color-muted)">
          0g0 ID を経由してログインしているサービスおよび IdP セッションの一覧です。
        </p>

        <div id="loading" class="flex items-center justify-center gap-2 py-4" style="color: var(--color-muted)">
          <span class="spinner"></span>
          <span>読み込み中...</span>
        </div>
        <div id="error" class="alert alert-error" style="display:none"></div>
        <div id="empty" class="text-center py-4" style="color: var(--color-muted); display:none">アクティブなセッションはありません</div>
        <div id="list" style="display:none"></div>
        <div id="actions" style="display:none">
          <hr class="my-5" style="border-color: var(--color-border)" />
          <button id="revoke-all-btn" class="btn btn-danger btn-full">すべてのセッションを無効化</button>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  import { apiFetch, formatDatetime } from '../lib/api';
  import { showToast } from '../lib/toast';
  import type { ActiveSession, ActiveBffSessionSummary } from '@0g0-id/api-types';

  const loadingEl = document.getElementById('loading')!;
  const errorEl = document.getElementById('error')!;
  const emptyEl = document.getElementById('empty')!;
  const listEl = document.getElementById('list')!;
  const actionsEl = document.getElementById('actions')!;
  const revokeAllBtn = document.getElementById('revoke-all-btn')!;

  const bffLoadingEl = document.getElementById('bff-loading')!;
  const bffErrorEl = document.getElementById('bff-error')!;
  const bffEmptyEl = document.getElementById('bff-empty')!;
  const bffListEl = document.getElementById('bff-list')!;

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (ch) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    } as Record<string, string>)[ch]!);
  }

  function formatUnixSec(sec: number): string {
    return formatDatetime(new Date(sec * 1000).toISOString());
  }

  async function loadBffSessions(): Promise<void> {
    bffLoadingEl.style.display = '';
    bffErrorEl.style.display = 'none';
    bffEmptyEl.style.display = 'none';
    bffListEl.style.display = 'none';

    const res = await apiFetch<ActiveBffSessionSummary[]>('/api/me/bff-sessions');
    bffLoadingEl.style.display = 'none';
    if ('error' in res) {
      bffErrorEl.textContent = 'ブラウザセッション一覧の取得に失敗しました';
      bffErrorEl.style.display = '';
      return;
    }
    const sessions = res as ActiveBffSessionSummary[];
    if (sessions.length === 0) {
      bffEmptyEl.style.display = '';
      return;
    }
    bffListEl.innerHTML = sessions.map((s) => {
      const boundBadge = s.has_device_key
        ? `<span class="badge badge-success text-xs ml-2" title="${s.device_bound_at ? 'バインド日時: ' + escapeHtml(formatUnixSec(s.device_bound_at)) : ''}" style="background: var(--color-accent); color: #fff; padding: 2px 6px; border-radius: 4px">
             <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" style="display:inline-block;vertical-align:-1px;margin-right:2px">
               <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
               <path d="M9 12l2 2 4-4"/>
             </svg>TPM バインド
           </span>`
        : `<span class="badge text-xs ml-2" title="このセッションはデバイスバインドされていません" style="background: var(--color-surface); color: var(--color-muted); padding: 2px 6px; border-radius: 4px">
             未バインド
           </span>`;
      const ua = s.user_agent ? escapeHtml(s.user_agent) : '（不明）';
      const ip = s.ip ? escapeHtml(s.ip) : '（不明）';
      const sid = escapeHtml(s.id);
      return `
        <div class="py-3.5 border-b last:border-b-0" style="border-color: var(--color-border)">
          <div class="flex items-center font-semibold text-sm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="14" rx="2"/><line x1="8" y1="20" x2="16" y2="20"/><line x1="12" y1="18" x2="12" y2="20"/></svg>
            <span class="ml-1.5">ブラウザセッション</span>
            ${boundBadge}
            <button class="btn btn-danger btn-sm ml-auto" data-revoke-bff="${sid}" aria-label="このブラウザセッションを失効">失効</button>
          </div>
          <div class="text-xs mt-1" style="color: var(--color-muted); word-break: break-all">
            UA: ${ua}
          </div>
          <div class="text-xs" style="color: var(--color-muted)">
            IP: ${ip}
          </div>
          <div class="text-xs mt-0.5" style="color: var(--color-muted)">
            作成: ${escapeHtml(formatUnixSec(s.created_at))} ／ 有効期限: ${escapeHtml(formatUnixSec(s.expires_at))}
          </div>
        </div>
      `;
    }).join('');
    bffListEl.style.display = '';
  }

  const BFF_REVOKE_CONFIRM =
    'このブラウザセッションを失効させます。現在使用中のセッションの場合、自動的にログアウトされます。refresh_token は別途「連携アプリケーション」セクションから失効する必要があります。よろしいですか？';

  bffListEl.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('[data-revoke-bff]') as HTMLButtonElement | null;
    if (!btn) return;
    const sid = btn.dataset.revokeBff;
    if (!sid) return;
    if (!confirm(BFF_REVOKE_CONFIRM)) return;
    btn.disabled = true;
    try {
      const res = await apiFetch(`/api/me/bff-sessions/${encodeURIComponent(sid)}`, {
        method: 'DELETE',
        headers: { Origin: window.location.origin },
      });
      if (res && typeof res === 'object' && 'error' in res) {
        showToast('ブラウザセッションの失効に失敗しました', 'error');
        btn.disabled = false;
        return;
      }
      // 現在使用中のセッションを失効した場合、サーバーが Set-Cookie で
      // __Host-user-session を削除している。クライアント側では HttpOnly
      // のため判別できないので、無条件でリロードして /login にフォールバックさせる。
      showToast('ブラウザセッションを失効しました', 'success');
      setTimeout(() => { window.location.reload(); }, 600);
    } catch {
      showToast('ブラウザセッションの失効に失敗しました', 'error');
      btn.disabled = false;
    }
  });

  async function loadSessions(): Promise<void> {
    loadingEl.style.display = '';
    errorEl.style.display = 'none';
    emptyEl.style.display = 'none';
    listEl.style.display = 'none';
    actionsEl.style.display = 'none';

    const res = await apiFetch<ActiveSession[]>('/api/me/sessions');
    loadingEl.style.display = 'none';
    if ('error' in res) {
      errorEl.textContent = 'セッション一覧の取得に失敗しました';
      errorEl.style.display = '';
      return;
    }
    const sessions = res as ActiveSession[];
    if (sessions.length === 0) {
      emptyEl.style.display = '';
      return;
    }
    listEl.innerHTML = sessions.map(s => `
      <div class="flex items-center justify-between py-3.5 border-b last:border-b-0" style="border-color: var(--color-border)">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-1.5 font-semibold text-sm">
            ${s.service_name
              ? `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/></svg>${escapeHtml(s.service_name)}`
              : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>0g0 ID（IdP セッション）`}
          </div>
          <div class="text-xs mt-0.5" style="color: var(--color-muted)">
            作成: ${formatDatetime(s.created_at)} ／ 有効期限: ${formatDatetime(s.expires_at)}
          </div>
        </div>
        <button class="btn btn-danger btn-sm ml-3" data-revoke="${s.id}">無効化</button>
      </div>
    `).join('');
    listEl.style.display = '';
    actionsEl.style.display = '';
  }

  listEl.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('[data-revoke]') as HTMLElement | null;
    if (!btn) return;
    const id = btn.dataset.revoke!;
    if (!confirm('このセッションを無効化しますか？')) return;
    const res = await apiFetch(`/api/me/sessions/${id}`, {
      method: 'DELETE',
      headers: { Origin: window.location.origin },
    });
    if ('error' in res) {
      showToast('無効化に失敗しました', 'error');
    } else {
      showToast('セッションを無効化しました', 'success');
      await loadSessions();
    }
  });

  revokeAllBtn.addEventListener('click', async () => {
    if (!confirm('すべてのセッションを無効化しますか？この操作後、ログアウトされます。')) return;
    const res = await apiFetch('/api/me/sessions', {
      method: 'DELETE',
      headers: { Origin: window.location.origin },
    });
    if ('error' in res) {
      showToast('無効化に失敗しました', 'error');
    } else {
      showToast('すべてのセッションを無効化しました', 'success');
      setTimeout(() => { window.location.href = '/'; }, 1200);
    }
  });

  await Promise.all([loadBffSessions(), loadSessions()]);
</script>
