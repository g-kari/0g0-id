---
<div class="card" style="margin-bottom:24px;">
  <div style="display:flex; align-items:center; gap:16px; padding:20px;">
    <div id="avatar" style="width:56px; height:56px; border-radius:50%; background:var(--color-surface); display:flex; align-items:center; justify-content:center; font-size:1.5rem; overflow:hidden;"></div>
    <div style="flex:1;">
      <h1 class="page-title" id="user-name" style="margin:0;"></h1>
      <p style="color:var(--color-muted); margin:4px 0 0;" id="user-email"></p>
    </div>
    <div style="display:flex; gap:8px;" id="badges"></div>
  </div>
</div>
