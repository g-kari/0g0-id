---
import Admin from '../../layouts/Admin.astro';
import LoadingState from '../../components/common/LoadingState.astro';
import ErrorState from '../../components/common/ErrorState.astro';
import UserHeader from '../../components/users/UserHeader.astro';
import UserInfoGrid from '../../components/users/UserInfoGrid.astro';
import SessionsCard from '../../components/users/SessionsCard.astro';
import BffSessionsCard from '../../components/users/BffSessionsCard.astro';
import LockoutCard from '../../components/users/LockoutCard.astro';
import UserActionsCard from '../../components/users/UserActionsCard.astro';
import ServiceSubsCard from '../../components/users/ServiceSubsCard.astro';
---
<Admin title="ユーザー詳細 — 0g0 Admin">
  <LoadingState />
  <ErrorState message="ユーザー情報の取得に失敗しました" backHref="/users" backLabel="← ユーザー一覧に戻る" />
  <div id="content" style="display:none;">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px;">
      <a href="/users" style="color:var(--color-muted); text-decoration:none; font-size:0.9rem;">← 一覧に戻る</a>
    </div>
    <UserHeader />
    <UserInfoGrid />
    <ServiceSubsCard />
    <SessionsCard />
    <BffSessionsCard />
    <LockoutCard />
    <UserActionsCard />
  </div>
</Admin>

<script>
  import { apiFetch, formatDate, formatDatetime } from '../../lib/api';
  import { escapeHtml } from '../../lib/helpers';
  import { showToast } from '../../lib/toast';
  import type { AdminUserSummary, ProviderStatus, ActiveSession, ActiveBffSessionSummary } from '@0g0-id/api-types';

  // URL からユーザーIDを取得
  const pathParts = window.location.pathname.split('/').filter(Boolean);
  // /users/detail?id=xxx or /users/:id → detail page
  const userId = new URLSearchParams(window.location.search).get('id')
    || (pathParts.length >= 2 && pathParts[0] === 'users' ? pathParts[1] : null);

  const loadingEl = document.getElementById('loading')!;
  const errorEl = document.getElementById('error')!;
  const contentEl = document.getElementById('content')!;

  if (!userId) {
    loadingEl.style.display = 'none';
    errorEl.style.display = '';
    throw new Error('No user ID');
  }

  type UserDetail = AdminUserSummary & {
    phone?: string | null;
    address?: string | null;
    email_verified?: number;
    google_sub?: string | null;
    line_sub?: string | null;
    twitch_sub?: string | null;
    github_sub?: string | null;
    x_sub?: string | null;
    updated_at?: string;
  };

  try {
    const [user, providers, sessions] = await Promise.all([
      apiFetch<UserDetail>(`/api/users/${userId}`),
      apiFetch<ProviderStatus[]>(`/api/users/${userId}/providers`),
      apiFetch<ActiveSession[]>(`/api/users/${userId}/tokens`),
    ]);
    // bff-sessions は新規エンドポイントのため、失敗しても既存UIを描画し続けられるよう分離
    let bffSessions: ActiveBffSessionSummary[] | null = null;
    try {
      bffSessions = await apiFetch<ActiveBffSessionSummary[]>(`/api/users/${userId}/bff-sessions`);
    } catch {
      bffSessions = null;
    }

    loadingEl.style.display = 'none';
    contentEl.style.display = '';

    // ヘッダー
    const avatarEl = document.getElementById('avatar')!;
    const nameEl = document.getElementById('user-name')!;
    const emailEl = document.getElementById('user-email')!;
    const badgesEl = document.getElementById('badges')!;

    if (user.picture) {
      avatarEl.innerHTML = `<img src="${escapeHtml(user.picture)}" style="width:100%;height:100%;object-fit:cover;" alt="">`;
    } else {
      avatarEl.textContent = (user.name || user.email)[0]?.toUpperCase() || '?';
    }
    nameEl.textContent = user.name || '(名前未設定)';
    emailEl.textContent = user.email;

    const isBanned = !!user.banned_at;
    badgesEl.innerHTML = `
      <span class="badge badge-${user.role}">${user.role === 'admin' ? '管理者' : 'ユーザー'}</span>
      ${isBanned ? '<span class="badge badge-banned">BAN</span>' : '<span class="badge badge-active">アクティブ</span>'}
    `;

    // 基本情報テーブル
    const infoTbody = document.getElementById('info-tbody')!;
    const infoRows = [
      ['ID (Sub)', user.id],
      ['作成日', formatDate(user.created_at)],
      ['ロール', user.role === 'admin' ? '管理者' : 'ユーザー'],
      ['状態', isBanned ? `BAN (${formatDate(user.banned_at!)})` : 'アクティブ'],
    ];
    infoTbody.innerHTML = infoRows.map(([label, value]) => `
      <tr>
        <td style="color:var(--color-muted); padding:4px 8px 4px 0; white-space:nowrap;">${label}</td>
        <td style="padding:4px 0; word-break:break-all;">${value}</td>
      </tr>
    `).join('');

    // プロバイダー
    const providersEl = document.getElementById('providers-list')!;
    const providerLabels: Record<string, string> = {
      google: 'Google', line: 'LINE', twitch: 'Twitch', github: 'GitHub', x: 'X',
    };
    if (Array.isArray(providers)) {
      providersEl.innerHTML = (providers as ProviderStatus[]).map((p) => `
        <div style="display:flex; align-items:center; justify-content:space-between; padding:6px 0; border-bottom:1px solid var(--color-border);">
          <span>${providerLabels[p.provider] || escapeHtml(p.provider)}</span>
          <span style="color:${p.connected ? 'var(--color-success)' : 'var(--color-muted)'};">${p.connected ? '✓ 連携済み' : '未連携'}</span>
        </div>
      `).join('');
    }

    // サービス連携 / Sub ID
    const serviceSubsEl = document.getElementById('service-subs-list')!;
    try {
      interface UserConnection {
        service_id: string;
        service_name: string;
        client_id: string;
        pairwise_sub: string | null;
        first_authorized_at: string;
        last_authorized_at: string;
      }
      const connections = await apiFetch<UserConnection[]>(`/api/users/${userId}/services`);
      if (connections.length === 0) {
        serviceSubsEl.innerHTML = '<p style="color:var(--color-muted); font-size:0.875rem;">連携しているサービスはありません</p>';
      } else {
        serviceSubsEl.innerHTML = `
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>サービス名</th>
                  <th>Sub ID (Pairwise)</th>
                  <th>初回認可</th>
                  <th>最終認可</th>
                </tr>
              </thead>
              <tbody>
                ${connections.map((c) => `
                  <tr>
                    <td><a href="/services/${escapeHtml(c.service_id)}" style="color:var(--color-accent); text-decoration:underline;">${escapeHtml(c.service_name)}</a></td>
                    <td style="font-family:monospace; font-size:0.75rem; word-break:break-all;">${c.pairwise_sub ? escapeHtml(c.pairwise_sub) : '<span style="color:var(--color-muted);">—</span>'}</td>
                    <td style="font-size:0.8rem; color:var(--color-muted);">${formatDate(c.first_authorized_at)}</td>
                    <td style="font-size:0.8rem; color:var(--color-muted);">${formatDate(c.last_authorized_at)}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>`;
      }
    } catch {
      serviceSubsEl.innerHTML = '<p style="color:var(--color-muted); font-size:0.875rem;">サービス連携情報の取得に失敗しました</p>';
    }

    // セッション
    const sessionsEl = document.getElementById('sessions-list')!;
    const revokeAllBtn = document.getElementById('revoke-all-btn')!;
    if (Array.isArray(sessions) && (sessions as ActiveSession[]).length > 0) {
      const sessionList = sessions as ActiveSession[];
      revokeAllBtn.style.display = '';
      sessionsEl.innerHTML = sessionList.map((s) => `
        <div style="display:flex; align-items:center; justify-content:space-between; padding:8px 0; border-bottom:1px solid var(--color-border);">
          <div>
            <div style="font-size:0.875rem;">${s.service_name ? escapeHtml(s.service_name) : 'BFFセッション'}</div>
            <div style="font-size:0.75rem; color:var(--color-muted);">作成: ${formatDatetime(s.created_at)} / 有効期限: ${formatDatetime(s.expires_at)}</div>
          </div>
          <button class="btn btn-ghost revoke-session-btn" data-id="${s.id}" style="font-size:0.75rem; padding:2px 8px;">無効化</button>
        </div>
      `).join('');

      // 個別セッション無効化
      document.querySelectorAll('.revoke-session-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const tokenId = (btn as HTMLElement).dataset.id;
          if (!confirm('このセッションを無効化しますか？')) return;
          try {
            await apiFetch(`/api/users/${userId}/tokens/${tokenId}`, { method: 'DELETE' });
            showToast('セッションを無効化しました');
            window.location.reload();
          } catch {
            showToast('セッション無効化に失敗しました', 'error');
          }
        });
      });
    } else {
      sessionsEl.innerHTML = '<p style="color:var(--color-muted); font-size:0.875rem;">アクティブなセッションはありません</p>';
    }

    // BFF セッション（DBSC バインド状態付き）
    const bffSessionsEl = document.getElementById('bff-sessions-list')!;

    const formatUnix = (t: number) => formatDatetime(new Date(t * 1000).toISOString());
    if (bffSessions === null) {
      bffSessionsEl.innerHTML = '<p style="color:var(--color-muted); font-size:0.875rem;">BFF セッションの取得に失敗しました</p>';
    } else if (Array.isArray(bffSessions) && bffSessions.length > 0) {
      const list = bffSessions as ActiveBffSessionSummary[];
      bffSessionsEl.innerHTML = list.map((s) => {
        const bound = s.has_device_key
          ? `<span class="badge" style="background:var(--color-success,#38a169); color:#fff; font-size:0.7rem; padding:2px 6px; border-radius:4px;">🔒 端末バインド済み</span>`
          : `<span class="badge" style="background:var(--color-surface); color:var(--color-muted); font-size:0.7rem; padding:2px 6px; border-radius:4px;">未バインド</span>`;
        const boundAt = s.device_bound_at
          ? `<div style="font-size:0.7rem; color:var(--color-muted);">バインド日時: ${formatUnix(s.device_bound_at)}</div>`
          : '';
        const origin = escapeHtml(s.bff_origin);
        const ua = s.user_agent ? escapeHtml(s.user_agent) : '(User-Agent 不明)';
        const sessionId = escapeHtml(s.id);
        return `
        <div style="padding:8px 0; border-bottom:1px solid var(--color-border);">
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
            <span style="font-size:0.875rem;">${origin}</span>
            ${bound}
            <button class="btn btn-ghost revoke-bff-session-btn" data-id="${sessionId}" style="font-size:0.7rem; padding:2px 8px; margin-left:auto;">失効</button>
          </div>
          <div style="font-size:0.7rem; color:var(--color-muted); word-break:break-all;">UA: ${ua}</div>
          <div style="font-size:0.75rem; color:var(--color-muted);">作成: ${formatUnix(s.created_at)} / 有効期限: ${formatUnix(s.expires_at)}</div>
          ${boundAt}
        </div>`;
      }).join('');

      // 個別 BFF セッション失効
      document.querySelectorAll('.revoke-bff-session-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const sessionId = (btn as HTMLElement).dataset.id;
          if (!confirm('この BFF セッションを失効させますか？\n\n注意: BFF Cookie のみ無効化します。refresh_token / 連携サービスのアクセスは「全セッション無効化」を別途実行してください。')) return;
          try {
            await apiFetch(`/api/users/${userId}/bff-sessions/${sessionId}`, { method: 'DELETE' });
            showToast('BFF セッションを失効しました');
            window.location.reload();
          } catch {
            showToast('BFF セッション失効に失敗しました', 'error');
          }
        });
      });
    } else {
      bffSessionsEl.innerHTML = '<p style="color:var(--color-muted); font-size:0.875rem;">アクティブな BFF セッションはありません</p>';
    }

    // 全セッション無効化
    revokeAllBtn.addEventListener('click', async () => {
      if (!confirm('このユーザーの全セッションを無効化しますか？')) return;
      try {
        await apiFetch(`/api/users/${userId}/tokens`, { method: 'DELETE' });
        showToast('全セッションを無効化しました');
        window.location.reload();
      } catch {
        showToast('全セッション無効化に失敗しました', 'error');
      }
    });

    // 操作ボタン
    const toggleRoleBtn = document.getElementById('toggle-role-btn')!;
    const toggleBanBtn = document.getElementById('toggle-ban-btn')!;
    const deleteBtn = document.getElementById('delete-btn')!;

    toggleRoleBtn.textContent = user.role === 'admin' ? 'ユーザーに降格' : '管理者に昇格';
    toggleBanBtn.textContent = isBanned ? 'BAN解除' : 'ユーザーBAN';
    if (isBanned) toggleBanBtn.classList.add('btn-ghost');
    else toggleBanBtn.classList.add('btn-danger');

    toggleRoleBtn.addEventListener('click', async () => {
      const newRole = user.role === 'admin' ? 'user' : 'admin';
      if (!confirm(`このユーザーを${newRole === 'admin' ? '管理者' : 'ユーザー'}に変更しますか？`)) return;
      try {
        await apiFetch(`/api/users/${userId}/role`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ role: newRole }),
        });
        showToast('ロールを変更しました');
        window.location.reload();
      } catch {
        showToast('ロール変更に失敗しました', 'error');
      }
    });

    toggleBanBtn.addEventListener('click', async () => {
      if (isBanned) {
        if (!confirm('このユーザーのBANを解除しますか？')) return;
        try {
          await apiFetch(`/api/users/${userId}/ban`, { method: 'DELETE' });
          showToast('BANを解除しました');
          window.location.reload();
        } catch {
          showToast('BAN解除に失敗しました', 'error');
        }
      } else {
        if (!confirm('このユーザーをBANしますか？')) return;
        try {
          await apiFetch(`/api/users/${userId}/ban`, { method: 'PATCH' });
          showToast('ユーザーをBANしました');
          window.location.reload();
        } catch {
          showToast('BAN処理に失敗しました', 'error');
        }
      }
    });

    deleteBtn.addEventListener('click', async () => {
      if (!confirm('このユーザーを完全に削除しますか？この操作は取り消せません。')) return;
      try {
        await apiFetch(`/api/users/${userId}`, { method: 'DELETE' });
        showToast('ユーザーを削除しました');
        window.location.href = '/users';
      } catch {
        showToast('ユーザー削除に失敗しました', 'error');
      }
    });

    // ロックアウト状態の取得・表示
    const lockoutCard = document.getElementById('lockout-card')!;
    const lockoutInfo = document.getElementById('lockout-info')!;
    const clearLockoutBtn = document.getElementById('clear-lockout-btn')!;

    try {
      const lockout = await apiFetch<{
        user_id: string;
        failed_attempts: number;
        locked_until: string | null;
        last_failed_at: string | null;
        is_locked?: boolean;
      }>(`/api/users/${userId}/lockout`);

      if (lockout.failed_attempts > 0 || lockout.locked_until) {
        lockoutCard.style.display = '';
        const isLocked = lockout.is_locked ?? (lockout.locked_until !== null && lockout.locked_until > new Date().toISOString());
        lockoutInfo.innerHTML = `
          <div style="display:flex; gap:16px; flex-wrap:wrap; font-size:0.875rem;">
            <div>
              <span style="color:var(--color-muted);">状態:</span>
              ${isLocked
                ? '<span style="color:var(--color-danger); font-weight:600;">🔒 ロック中</span>'
                : '<span style="color:var(--color-success);">解除済み</span>'}
            </div>
            <div>
              <span style="color:var(--color-muted);">失敗回数:</span>
              <span style="font-weight:600;">${lockout.failed_attempts}</span>
            </div>
            ${lockout.locked_until ? `<div><span style="color:var(--color-muted);">ロック期限:</span> ${formatDatetime(lockout.locked_until)}</div>` : ''}
            ${lockout.last_failed_at ? `<div><span style="color:var(--color-muted);">最終失敗:</span> ${formatDatetime(lockout.last_failed_at)}</div>` : ''}
          </div>
        `;
        clearLockoutBtn.style.display = '';
        clearLockoutBtn.addEventListener('click', async () => {
          if (!confirm('ロックアウトを解除しますか？失敗回数もリセットされます。')) return;
          try {
            await apiFetch(`/api/users/${userId}/lockout`, { method: 'DELETE' });
            showToast('ロックアウトを解除しました');
            window.location.reload();
          } catch {
            showToast('ロックアウト解除に失敗しました', 'error');
          }
        });
      }
    } catch {
      // ロックアウト情報取得失敗は無視
    }

  } catch {
    loadingEl.style.display = 'none';
    errorEl.style.display = '';
  }
</script>
