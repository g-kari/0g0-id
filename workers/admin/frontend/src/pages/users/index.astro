---
import Admin from '../../layouts/Admin.astro';
---
<Admin title="ユーザー管理 — 0g0 Admin">
  <div class="page-header" style="display:flex; align-items:center; justify-content:space-between;">
    <div>
      <h1 class="page-title">ユーザー管理</h1>
      <p class="page-subtitle" id="user-count">読み込み中...</p>
    </div>
    <div class="form-group" style="flex-direction:row; align-items:center; gap:8px;">
      <label for="status-filter" style="white-space:nowrap;">状態:</label>
      <select id="status-filter">
        <option value="all">すべて</option>
        <option value="active">アクティブ</option>
        <option value="banned">BAN</option>
      </select>
    </div>
  </div>

  <!-- DBSC バインド集計サマリ（issue #155 Phase 3: Chrome 非対応環境の棚卸し用） -->
  <div id="dbsc-summary" class="card" style="display:none; margin-bottom:16px; padding:16px;">
    <h3 style="margin:0 0 8px; font-size:0.9rem; color:var(--color-muted);">BFF セッションの DBSC 端末バインド状況</h3>
    <div id="dbsc-summary-body" style="font-size:0.875rem;"></div>
  </div>

  <div id="loading" style="display:flex; justify-content:center; padding:3rem;">
    <div class="spinner"></div>
  </div>
  <div id="error" class="alert alert-error" style="display:none;" aria-live="polite"></div>
  <div id="table-wrap" class="card" style="padding:0; overflow:hidden; display:none;">
    <table class="data-table">
      <thead>
        <tr>
          <th>名前</th>
          <th>メールアドレス</th>
          <th>ロール</th>
          <th>状態</th>
          <th>登録日</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody id="user-tbody"></tbody>
    </table>
    <div id="empty-message" style="padding:2rem; text-align:center; color:var(--color-muted); display:none;">ユーザーが見つかりません</div>
  </div>
</Admin>

<script>
  import { apiFetch, formatDate } from '../../lib/api';
  import type { AdminUserSummary, BffSessionDbscStats } from '@0g0-id/api-types';

  type UserRow = AdminUserSummary & { status: 'active' | 'banned' };

  const loadingEl = document.getElementById('loading')!;
  const errorEl = document.getElementById('error')!;
  const tableWrap = document.getElementById('table-wrap')!;
  const tbody = document.getElementById('user-tbody')!;
  const emptyMsg = document.getElementById('empty-message')!;
  const countEl = document.getElementById('user-count')!;
  const filterEl = document.getElementById('status-filter') as HTMLSelectElement;
  const dbscSummaryEl = document.getElementById('dbsc-summary')!;
  const dbscSummaryBodyEl = document.getElementById('dbsc-summary-body')!;

  const escapeHtml = (s: string) => s.replace(/[&<>"']/g, (ch) => ({
    '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
  }[ch] as string));

  async function loadDbscSummary(): Promise<void> {
    try {
      const stats = await apiFetch<BffSessionDbscStats>('/api/metrics/dbsc-bindings');
      if (
        !stats ||
        typeof stats !== 'object' ||
        !('total' in stats) ||
        !Array.isArray((stats as BffSessionDbscStats).by_bff_origin)
      ) {
        return;
      }
      const total = stats.total;
      const bound = stats.device_bound;
      const unbound = stats.unbound;
      const boundPct = total > 0 ? Math.round((bound / total) * 1000) / 10 : 0;
      const badge = (label: string, value: number, color: string) =>
        `<span style="display:inline-block; padding:4px 10px; border-radius:999px; background:${color}; color:#fff; font-size:0.75rem; font-weight:600; margin-right:8px;">${label}: ${value}</span>`;
      const originRows = stats.by_bff_origin
        .map((o) => {
          const pct = o.total > 0 ? Math.round((o.device_bound / o.total) * 1000) / 10 : 0;
          return `<tr>
            <td style="padding:4px 8px 4px 0; color:var(--color-muted); word-break:break-all;">${escapeHtml(o.bff_origin)}</td>
            <td style="padding:4px 8px; text-align:right;">${o.total}</td>
            <td style="padding:4px 8px; text-align:right; color:var(--color-success);">${o.device_bound}</td>
            <td style="padding:4px 8px; text-align:right; color:var(--color-muted);">${o.unbound}</td>
            <td style="padding:4px 0; text-align:right; color:var(--color-muted); font-variant-numeric:tabular-nums;">${pct.toFixed(1)}%</td>
          </tr>`;
        })
        .join('');
      dbscSummaryBodyEl.innerHTML = `
        <div style="margin-bottom:10px;">
          ${badge('全体', total, 'var(--color-muted)')}
          ${badge('端末バインド済み', bound, 'var(--color-success, #2d7a3a)')}
          ${badge('未バインド', unbound, 'var(--color-danger, #c0392b)')}
          <span style="color:var(--color-muted); font-size:0.8rem;">バインド率 ${boundPct.toFixed(1)}%</span>
        </div>
        ${stats.by_bff_origin.length > 0 ? `
          <table style="width:100%; font-size:0.8rem;">
            <thead>
              <tr style="color:var(--color-muted);">
                <th style="text-align:left; padding:2px 8px 2px 0; font-weight:500;">BFF origin</th>
                <th style="text-align:right; padding:2px 8px; font-weight:500;">合計</th>
                <th style="text-align:right; padding:2px 8px; font-weight:500;">バインド済み</th>
                <th style="text-align:right; padding:2px 8px; font-weight:500;">未バインド</th>
                <th style="text-align:right; padding:2px 0; font-weight:500;">バインド率</th>
              </tr>
            </thead>
            <tbody>${originRows}</tbody>
          </table>
        ` : ''}
      `;
      dbscSummaryEl.style.display = '';
    } catch {
      // 集計取得失敗時はユーザー一覧表示を邪魔しないよう静かに隠す
      dbscSummaryEl.style.display = 'none';
    }
  }

  async function loadUsers(): Promise<void> {
    loadingEl.style.display = 'flex';
    errorEl.style.display = 'none';
    tableWrap.style.display = 'none';

    try {
      const status = filterEl.value;
      const params = status !== 'all' ? `?status=${status}` : '';
      const raw = await apiFetch<AdminUserSummary[]>(`/api/users${params}`);
      const users: UserRow[] = (raw as AdminUserSummary[]).map((u) => ({
        ...u,
        status: u.banned_at ? 'banned' as const : 'active' as const,
      }));

      countEl.textContent = `${users.length} 件`;
      tbody.innerHTML = users
        .map(
          (user) => `
        <tr>
          <td>${user.name ?? '—'}</td>
          <td style="color:var(--color-muted); font-size:0.875rem;">${user.email}</td>
          <td><span class="badge badge-${user.role}">${user.role === 'admin' ? '管理者' : 'ユーザー'}</span></td>
          <td><span class="badge badge-${user.status}">${user.status === 'active' ? 'アクティブ' : 'BAN'}</span></td>
          <td style="color:var(--color-muted); font-size:0.875rem;">${formatDate(user.created_at)}</td>
          <td><a href="/users/${user.id}" class="btn btn-ghost" style="padding:4px 10px; font-size:0.8rem;">詳細</a></td>
        </tr>
      `,
        )
        .join('');

      emptyMsg.style.display = users.length === 0 ? '' : 'none';
      tableWrap.style.display = '';
    } catch (e) {
      errorEl.textContent = e instanceof Error ? e.message : '読み込みに失敗しました';
      errorEl.style.display = '';
    } finally {
      loadingEl.style.display = 'none';
    }
  }

  filterEl.addEventListener('change', loadUsers);
  loadUsers();
  loadDbscSummary();
</script>
