{
  "name": "workers-id",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "build:assets": "tsx scripts/build-assets.ts",
    "migrate": "wrangler d1 migrations apply 0g0-id-db --remote",
    "deploy": "wrangler d1 migrations apply 0g0-id-db --remote && vp build && npm run build:assets && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vp test run"
  },
  "dependencies": {
    "@0g0-id/shared": "*",
    "hono": "^4.12.14",
    "jose": "^6.2.2",
    "tldts": "^7.0.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.2",
    "@cloudflare/workers-types": "^4.20260415.1",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "^0.1.18",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wrangler": "^4.78.0"
  }
}
